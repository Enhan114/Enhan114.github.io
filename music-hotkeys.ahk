; ──────────────────────────────────────────────
; Aura Music — 系统级快捷键 (AutoHotkey v2)
;
; 依赖: 浏览器扩展 (ext/ 目录，需先加载到 Edge)
;
; 按键 → 发送 Ctrl+Shift+6/7/8
; 扩展监听到后 → 触发网页里的播放控制
; ──────────────────────────────────────────────

#Requires AutoHotkey v2.0

$6::SendInput("^+6")    ; 上一首
$7::SendInput("^+7")    ; 播放/暂停
$8::SendInput("^+8")    ; 下一首
